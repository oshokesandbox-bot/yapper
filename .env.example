# === Yapper Environment Variables ===
# Copy this file to .env and fill in your values.

# --- API ---
NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yapper?schema=public"
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_ACCESS_SECRET="replace-with-random-string-at-least-32-chars"
JWT_REFRESH_SECRET="replace-with-another-random-string-at-least-32-chars"

# --- OAuth (optional) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- AI (optional - mock used when not set) ---
OPENAI_API_KEY=""

# --- Stripe (optional) ---
STRIPE_SECRET_KEY=""

# --- S3 / Media Storage (optional) ---
S3_BUCKET=""

# --- Frontend ---
# Points to the deployed API URL (Render), or http://localhost:4000 for local dev
NEXT_PUBLIC_API_URL="http://localhost:4000"
