{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@yapper/shared": ["packages/shared/src/index.ts"],
      "@yapper/ui": ["packages/ui/src/index.ts"],
      "@yapper/ai-core": ["packages/ai-core/src/index.ts"],
      "@yapper/audio": ["packages/audio/src/index.ts"],
      "@yapper/config": ["packages/config/src/index.ts"]
    }
  }
}
