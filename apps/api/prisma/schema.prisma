generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LanguageCode {
  EN
  FR
  ES
  DE
  RU
}

enum LaunchTier {
  MVP
  SEED
}

enum LessonStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum ContentKind {
  MOVIE_RECOMMENDATION
  MICRO_STORY
  DIALOGUE
  VOCABULARY_CARD
  MINIMAL_PAIR
  SENTENCE_PROMPT
  COMPREHENSION_QUESTION
  COMPOSITION_PROMPT
}

enum ReviewState {
  PENDING
  APPROVED
  REJECTED
  EDITED
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  passwordHash   String?
  displayName    String?
  googleId       String?      @unique
  avatarUrl      String?
  nativeLanguage LanguageCode?
  isAdmin        Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  sessions     AuthSession[]
  progresses   UserLanguageProgress[]
  lessonProgress UserLessonProgress[]
  vocabularyProgress UserVocabularyProgress[]
  contentReviews ContentReview[]
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Language {
  code        LanguageCode @id
  englishName String
  nativeName  String
  launchTier  LaunchTier
  script      String
  isActive    Boolean      @default(true)

  lessons    Lesson[]
  mediaRecs  MediaRecommendation[]
  aiGenerations AiGeneration[]
}

model Stage {
  id       Int     @id
  slug     String  @unique
  label    String
  userStep Int
  purpose  String
  isMvp    Boolean @default(false)

  lessons    Lesson[]
  progresses UserLanguageProgress[]
}

model UserLanguageProgress {
  id             String       @id @default(cuid())
  userId         String
  language       LanguageCode
  currentStageId Int
  stageProgress  Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user         User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStage Stage @relation(fields: [currentStageId], references: [id])

  @@unique([userId, language])
  @@index([language, currentStageId])
}

model Lesson {
  id          String       @id @default(cuid())
  language    LanguageCode
  stageId     Int
  title       String
  description String?
  subtitle    String?
  estimatedMinutes Int?
  status      LessonStatus @default(DRAFT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  stage       Stage       @relation(fields: [stageId], references: [id])
  languageRef Language     @relation(fields: [language], references: [code])
  steps       LessonStep[]
  userProgress UserLessonProgress[]
}

model LessonStep {
  id        String      @id @default(cuid())
  lessonId  String
  order     Int
  kind      ContentKind
  payload   Json
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, order])
}

model UserLessonProgress {
  id        String       @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean      @default(false)
  score     Float?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model VocabularyItem {
  id              String       @id @default(cuid())
  language        LanguageCode
  term            String
  translation     String
  concept         String
  pronunciationHint String?
  stageSlug       String
  createdAt       DateTime     @default(now())

  userProgress UserVocabularyProgress[]

  @@index([language, stageSlug])
}

model UserVocabularyProgress {
  id              String   @id @default(cuid())
  userId          String
  vocabularyId    String
  mastered        Boolean  @default(false)
  reviewCount     Int      @default(0)
  lastReviewedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary VocabularyItem @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
}

model MediaRecommendation {
  id           String       @id @default(cuid())
  language     LanguageCode
  title        String
  mediaType    String
  reason       String
  challenge    String?
  affiliateUrl String?
  stageHintId  Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  languageRef Language @relation(fields: [language], references: [code])
}

model AiGeneration {
  id          String      @id @default(cuid())
  language    LanguageCode
  stageSlug   String
  kind        ContentKind
  prompt      String
  output      Json
  reviewState ReviewState @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  languageRef Language @relation(fields: [language], references: [code])
  review       ContentReview?
}

model ContentReview {
  id              String      @id @default(cuid())
  aiGenerationId  String      @unique
  reviewerId      String?
  reviewNotes     String?
  reviewState     ReviewState @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  aiGeneration AiGeneration @relation(fields: [aiGenerationId], references: [id], onDelete: Cascade)
  reviewer     User?        @relation(fields: [reviewerId], references: [id])

  @@index([reviewState])
}
