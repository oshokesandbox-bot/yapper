NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yapper?schema=public"

# Auth
JWT_ACCESS_SECRET="change-me-to-a-random-string-at-least-32-chars"
JWT_REFRESH_SECRET="change-me-to-another-random-string-at-least-32-chars"

# OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI (optional - mock used when not set)
OPENAI_API_KEY=""

# Redis (optional)
REDIS_URL=""

# Stripe (optional)
STRIPE_SECRET_KEY=""
